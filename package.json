{
  "name": "enterprise-mobile-automation-framework",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready mobile automation framework built with Appium 2, WebdriverIO, Mocha, and JavaScript ES2023",
  "main": "index.js",
  "scripts": {
    "android": "node scripts/run-tests.js android",
    "ios": "node scripts/run-tests.js ios",
    "emulator": "node scripts/run-tests.js emulator",
    "real-device": "node scripts/run-tests.js real-device",
    "smoke": "node scripts/run-tests.js smoke",
    "regression": "node scripts/run-tests.js regression",
    "parallel": "node scripts/run-tests.js parallel",
    "web": "node scripts/run-tests.js web --platform web --appType desktop-web --browser chrome",
    "chrome": "node scripts/run-tests.js web --platform web --appType desktop-web --browser chrome",
    "edge": "node scripts/run-tests.js web --platform web --appType desktop-web --browser MicrosoftEdge",
    "firefox": "node scripts/run-tests.js web --platform web --appType desktop-web --browser firefox",
    "safari": "node scripts/run-tests.js web --platform web --appType desktop-web --browser safari",
    "test": "node scripts/run-tests.js all",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "allure:generate": "node scripts/run-allure.js generate reports/allure-results --clean -o reports/allure-report",
    "allure:open": "node scripts/run-allure.js open reports/allure-report",
    "prepare": "husky install"
  },
  "dependencies": {
    "@wdio/allure-reporter": "^9.15.0",
    "@wdio/cli": "^9.15.0",
    "@wdio/mocha-framework": "^9.15.0",
    "@wdio/spec-reporter": "^9.15.0",
    "appium": "^2.12.0",
    "csv-parse": "^5.0.0",
    "dotenv": "^16.6.0",
    "expect-webdriverio": "^5.0.0",
    "lodash": "^4.17.21",
    "webdriverio": "^9.15.0",
    "winston": "^3.17.0",
    "xlsx": "^0.18.1"
  },
  "devDependencies": {
    "@wdio/local-runner": "^9.29.1",
    "allure-commandline": "^2.43.0",
    "appium-uiautomator2-driver": "^2.45.1",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.5.0",
    "rimraf": "^6.0.0"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
